# =============================================
# Azubi Webapp — Production Environment Variables
# Copy this file to .env.production (or .env) before deploy
# IMPORTANT:
# - Replace azubivn.de with your real domain
# - Use strong JWT secrets and DB/MinIO credentials
# =============================================

# ---- Runtime ----
NODE_ENV=production

# ---- Database (PostgreSQL) ----
# Update these values to your production database credentials.
DB_USER=azubi_user
DB_PASSWORD=change_me
DB_NAME=azubi_db

# ---- JWT Auth ----
# Use long, random, secure values in production.
JWT_SECRET=replace_with_strong_jwt_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ---- AI Tutor (Google GenAI) ----
GEMINI_API_KEY=replace_with_gemini_api_key

# ---- MinIO (S3-compatible file storage) ----
MINIO_USER=replace_with_minio_user
MINIO_PASSWORD=replace_with_minio_password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_PUBLIC_URL=https://azubivn.de/minio

# ---- Backend ----
BACKEND_PORT=3001
CORS_ORIGIN=https://azubivn.de,https://www.azubivn.de

# ---- Frontend ----
# If frontend is served behind Nginx on the same domain, keep /api.
# If using a separate API domain, set full URL (e.g. https://api.azubivn.de/api).
NEXT_PUBLIC_API_URL=/api
# Optional icon cache-busting version (used at frontend image build time). Bump this value when favicon/icon changes.
NEXT_PUBLIC_ICON_VERSION=20260411

# ---- Cloudflare Zero Trust ----
# Điền Token của Cloudflare Tunnel vào đây để cấu hình kết nối ra ngoài mà không cần mở Port Host
CLOUDFLARE_TOKEN=[ĐIỀN_TOKEN_CLOUDFLARE_VÀO_ĐÂY]

# ---- OAuth Social Login (Google + Facebook) ----
# GOOGLE: Tạo tại https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_CALLBACK_URL=https://azubivn.de/api/auth/google/callback

# FACEBOOK: Tạo tại https://developers.facebook.com/ → My Apps → Create App
FACEBOOK_APP_ID=replace_with_facebook_app_id
FACEBOOK_APP_SECRET=replace_with_facebook_app_secret
FACEBOOK_CALLBACK_URL=https://azubivn.de/api/auth/facebook/callback

# URL của Frontend (dùng để redirect về sau OAuth)
FRONTEND_URL=https://azubivn.de
# Optional comma-separated social/profile URLs for Organization/WebSite JSON-LD `sameAs`
# Example: https://www.facebook.com/azubivn,https://www.linkedin.com/company/azubivn
NEXT_PUBLIC_BRAND_SAME_AS=
