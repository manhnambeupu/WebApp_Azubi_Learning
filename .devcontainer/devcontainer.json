{
  "name": "Azubi Webapp Workspace",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },
  "forwardPorts": [3000, 3001, 5432, 5555, 9000, 9001],
  "portsAttributes": {
    "3000": { "label": "Frontend (Next.js)", "onAutoForward": "notify" },
    "3001": { "label": "Backend API", "onAutoForward": "silent" },
    "9000": { "label": "MinIO API", "onAutoForward": "silent" },
    "9001": { "label": "MinIO Console", "onAutoForward": "silent" },
    "5555": { "label": "Prisma Studio", "onAutoForward": "silent" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" }
  },
  "postCreateCommand": "cp .env.example .env && npm install -g pnpm && npm ci --prefix apps/backend && npm ci --prefix apps/frontend"
}
